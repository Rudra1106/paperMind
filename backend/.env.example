# PaperMind Backend — Environment Variables
# Copy this to .env and fill in your actual values.
# Never commit the real .env file to version control.

# ─── OpenRouter (our LLM calls — concept extraction, professor chat) ──────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Cognee Cloud ─────────────────────────────────────────────────────────────
# From your Cognee Cloud dashboard → API Keys and Connection Details.
#
# HOW IT WORKS:
#   cognee.serve() reads COGNEE_SERVICE_URL + COGNEE_API_KEY to route all
#   Cognee operations (remember, recall, forget) to YOUR cloud tenant.
#   Cognee Cloud runs its own LLM pipeline on the server side — you do NOT
#   need to provide LLM/embedding keys for Cognee when in Cloud mode.
#
# Your tenant URL from Connection Details (API Base URL):
COGNEE_SERVICE_URL=https://tenant-33024c0c-20ea-401f-bd94-bd5fa7e04cf2.aws.cognee.ai
# Your X-Api-Key from API Keys section:
COGNEE_API_KEY=your-cognee-api-key-here

# ─── LLM/Embedding config (LOCAL mode only — not needed for Cognee Cloud) ─────
# These are only used if COGNEE_SERVICE_URL is blank (local SQLite+LanceDB mode).
# In Cloud mode, Cognee runs its own LLM pipeline. Leave them blank if unsure.
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=deepseek/deepseek-chat:free
LLM_ENDPOINT=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_ENDPOINT=

# ─── Application ──────────────────────────────────────────────────────────────
# Controls allowed CORS origins (comma-separated). Set to your frontend URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
